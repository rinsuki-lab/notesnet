{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["src/client/api/**", "dist/**", "node_modules/**", "openapi.json"],
  "tabWidth": 4,
  "semi": false,
  "printWidth": 120,
  "arrowParens": "avoid",
  "trailingComma": "es5",
  "sortImports": true,
  "overrides": [
    {
      "files": ["*.yml", "*.md", "*.json", "*.graphql"],
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
