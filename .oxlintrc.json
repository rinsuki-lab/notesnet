{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "eslint/no-unused-vars": ["error", {
      "argsIgnorePattern": "^t$"
    }],
    "typescript/no-base-to-string": ["error", {
      "ignoredTypeNames": ["ErrorLike"]
    }],
    "typescript/restrict-template-expressions": ["error", {
      "allow": [{
        "from": "package",
        "name": "ErrorLike",
        "package": "@apollo/client"
      }]
    }]
  },
  "env": {
    "builtin": true
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "ignorePatterns": [
    "src/client/api/internal/**"
  ]
}